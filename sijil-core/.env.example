# SIJIL Backend Environment Configuration
# Copy this file to .env and fill in your values
# --- Database ---

# Server Configuration
PORT=4000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/sijil
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/sijil

# Redis Configuration (for BullMQ queues)
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=http://localhost:6379
UPSTASH_REDIS_REST_TOKEN=default

# Asset Storage Configuration
ASSET_BASE_URL=https://raw.githubusercontent.com/your-org/sijil-assets/main
ASSET_REPO_OWNER=your-org
ASSET_REPO_NAME=sijil-assets
ASSET_REPO_BRANCH=main

# GitHub Personal Access Token (for batch imports)
GITHUB_PAT=ghp_your_token_here

# Admin Configuration
ADMIN_SECRET=your_admin_secret_key_change_this

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info

# Export Configuration
EXPORT_TEMP_DIR=/tmp/sijil-exports
EXPORT_MAX_CONCURRENT=3

# Queue Configuration
QUEUE_CONCURRENCY=5
QUEUE_DEFAULT_DELAY=1000
